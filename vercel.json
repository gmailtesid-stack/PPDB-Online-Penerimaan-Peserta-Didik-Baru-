{
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.6.2"
    },
    "api/migrate.php": {
      "runtime": "vercel-php@0.6.2"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/img/(.*)",
      "dest": "/img/$1"
    },
    {
      "src": "/files/(.*)",
      "dest": "/files/$1"
    },
    {
      "src": "/run-migrate",
      "dest": "/api/migrate.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}